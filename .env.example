# Copy to .env (gitignored) and adjust as needed for your environment.
#
# The BENEFICIARY multisig is HARDCODED in script/Deploy.s.sol and the contracts —
# it does not need to be supplied here.

# Optional: private Base RPC URL. If unset, the script uses Base's public endpoint
# at https://mainnet.base.org (rate-limited but works for a one-off deploy).
# BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
